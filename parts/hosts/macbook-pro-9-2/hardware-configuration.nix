# Initially generated by 'nixos-generate-config', now the checked-in,
# hand-maintained hardware source of truth for this host -- it is NOT
# regenerated (disko.nix owns the install-time layout). Make changes here
# (e.g. the btrfsOpts below) or in the host's default.nix.
{
  config,
  lib,
  pkgs,
  site,
  modulesPath,
  ...
}:

let
  btrfsOpts = [
    "compress=zstd:1" # zstd:1 — 90% of zstd:3 compression, less CPU on 2C/4T
    "noatime"
    "ssd"
    "discard=async"
    # commit=30 (kernel default). Previously 120: reduced to avoid the
    # "btrfs-transacti blocked >120s → hung_task → journald watchdog" hang
    # cascade. Under libata.force=noncq only ONE I/O outstanding at a time,
    # so big accumulated transactions flush too slowly to meet the 120 s
    # hung_task threshold. 30 s interval = smaller flush batches.
    "commit=30"
  ];
in
{
  imports = [
    (modulesPath + "/installer/scan/not-detected.nix")
  ];

  boot.initrd.availableKernelModules = [
    "xhci_pci"
    "ehci_pci"
    "ahci"
    "firewire_ohci"
    "usbhid"
    "usb_storage"
    "sd_mod"
    "sr_mod"
    "sdhci_pci"
  ];
  boot.initrd.kernelModules = [ ];
  boot.kernelModules = [ "kvm-intel" ];
  boot.extraModulePackages = [ ];

  boot.initrd.luks.devices."cryptroot".device =
    "/dev/disk/by-uuid/0d4eafad-07a3-4404-ad90-301b416bbb53";
  # Process dm-crypt inline (skip the kcryptd workqueues) -- I/O-path-only win,
  # cipher/key/KDF unchanged. Smaller gain than NVMe but free on this SATA SSD.
  boot.initrd.luks.devices."cryptroot".bypassWorkqueues = true;
  # Pass TRIM through dm-crypt: without this every discard=async and fstrim
  # request dies at the crypt layer (lsblk --discard showed DISC-GRAN 0B).
  # Accepted trade: free-space patterns visible to disk forensics -- same
  # call already made for cryptswap/cryptbackup.
  boot.initrd.luks.devices."cryptroot".allowDiscards = true;

  # Declarative machine identity, pinned in the site registry: managed
  # /etc content (the overlay's lower layer) instead of a runtime file
  # that regenerates -- and therefore survives reinstalls. Content matches
  # what systemd wrote at first boot, so adopting the pin is a no-op.
  environment.etc."machine-id" = {
    text = site.hosts.macbook-pro-9-2.machineId + "\n";
    mode = "0444";
  };

  fileSystems."/" = {
    device = "/dev/mapper/cryptroot";
    fsType = "btrfs";
    options = [ "subvol=@" ] ++ btrfsOpts;
  };

  fileSystems."/home" = {
    device = "/dev/mapper/cryptroot";
    fsType = "btrfs";
    options = [ "subvol=@home" ] ++ btrfsOpts;
  };

  fileSystems."/nix" = {
    device = "/dev/mapper/cryptroot";
    fsType = "btrfs";
    options = [ "subvol=@nix" ] ++ btrfsOpts;
  };

  fileSystems."/var/log" = {
    device = "/dev/mapper/cryptroot";
    fsType = "btrfs";
    # nodatacow disables copy-on-write for log files (append-only workload).
    # CoW fragments append-heavy files + amplifies writes; append-only
    # logs don't need CoW checksums. ~5-10% less SSD writes on /var/log.
    # Applies to NEW files after mount (log rotation gives us that).
    # NOTE: nodatacow also disables compression -- the compress= token pulled
    # in via btrfsOpts below is inert on this mount (btrfs precedence).
    options = [
      "subvol=@log"
      "nodatacow"
    ]
    ++ btrfsOpts;
  };

  fileSystems."/var/cache" = {
    device = "/dev/mapper/cryptroot";
    fsType = "btrfs";
    options = [ "subvol=@cache" ] ++ btrfsOpts;
  };

  fileSystems."/tmp" = {
    device = "/dev/mapper/cryptroot";
    fsType = "btrfs";
    options = [ "subvol=@tmp" ] ++ btrfsOpts;
  };

  fileSystems."/.snapshots" = {
    device = "/dev/mapper/cryptroot";
    fsType = "btrfs";
    options = [ "subvol=@snapshots" ] ++ btrfsOpts;
  };

  fileSystems."/boot" = {
    device = "/dev/disk/by-uuid/4827-778F";
    fsType = "vfat";
    options = [
      "fmask=0077"
      "dmask=0077"
    ];
  };

  swapDevices = [ ];

  nixpkgs.hostPlatform = lib.mkDefault "x86_64-linux";
  hardware.cpu.intel.updateMicrocode = lib.mkDefault config.hardware.enableRedistributableFirmware;
}
