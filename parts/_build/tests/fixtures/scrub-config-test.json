{
  "_comment": "Minimal scrub-config for hook tests. Mirrors real config shape.",
  "forbidden_tokens": {
    "identity": ["Daaboulex"],
    "projects": ["Acme-Internal"]
  },
  "forbidden_patterns": {
    "private_project_paths": ["~/Documents/(?!nix\\b)[A-Z][a-zA-Z0-9_-]+"],
    "private_project_names": ["\\b(Acme|Widget)-[A-Z][a-zA-Z]+\\b"]
  },
  "rewrites": {
    "Acme-Internal": "[sub-project]"
  },
  "allow_in_docs": ["Daaboulex"],
  "context_allowlist": {
    "Daaboulex": ["flake.nix", "flake.lock", ".gitmodules", "**/*.nix"]
  }
}
