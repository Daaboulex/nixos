    # enable = false;  # boolean — Static hugepage allocation for VM memory
    # size = "2M";  # one of "2M", "1G" — Hugepage size (1G = fewer TLB misses, best for gaming VMs)

# --- vfio.lookingGlass (2 options) ---
    # enable = true;  # boolean — KVMFR shared memory for Looking Glass frame relay
    # memoryMB = 64;  # signed integer — KVMFR shared memory size in MB (32=1440p SDR, 64=4K SDR, 128=4K HDR)

# --- vfio.staticPciIds (1 options) ---
    # vfio.staticPciIds = [ ];  # list of string — PCI vendor:device IDs for static vfio-pci binding (e.g. ["1002:7550" "1002:ab...

# --- vfio.stealth (8 options) ---
    # enable = true;  # boolean — Build patched QEMU with anti-detection + KVM kernel patches for RDTSC spoofing
    # macPrefix = "04:42:1a";  # string — MAC address OUI prefix (default: ASUS)
    # smbios.biosVendor = "American Megatrends Inc.";  # string — SMBIOS BIOS vendor
    # smbios.biosVersion = "2101";  # string — SMBIOS BIOS version
    # smbios.manufacturer = "ASUSTeK COMPUTER INC.";  # string — SMBIOS system manufacturer
    # smbios.product = "ROG CROSSHAIR X870E HERO";  # string — SMBIOS product name
    # smbios.serial = "System Serial Number";  # string — SMBIOS system serial number
    # spoofMac = true;  # boolean — Generate realistic MAC addresses with a real vendor OUI prefix

# --- vfio.vms (1 options) ---

    # ... and 1 more options with complex defaults (see docs/OPTIONS.md)
  };

  # System basics (edit these for your host)
  system.stateVersion = "26.05";
  networking.hostName = "<hostname>";
  time.timeZone = "Europe/Berlin";
}
