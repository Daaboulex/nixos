# ==========================================================================
# NixOS Host Configuration Template
# ==========================================================================
# Auto-generated from myModules option definitions.
# 237 options across 13 namespaces.
#
# Usage: copy this file to parts/hosts/<hostname>/default.nix and uncomment
# the options you want to set. Options left commented use their module defaults.
#
# Regenerate: nix-build scripts/generate-host-template.nix --no-out-link
# ==========================================================================
{
  config,
  pkgs,
  inputs,
  lib,
  ...
}:
{
  imports = [
    ./hardware-configuration.nix
  ];

  myModules = {
# --------------------------------------------------------------------------
# audio (35 options)
# --------------------------------------------------------------------------
    # attenuationLimit: signed integer — Max noise attenuation in dB (0-100). 100 = no limit (official default). 6-12 = light, 18-24 = medium.
    # attenuationLimit = 100;
    # enable: boolean — Whether to enable DeepFilterNet3 neural noise suppression on chat mic.
    # enable = false;
    # maxDfThreshold: floating point number — Max DF processing threshold in dB (-15 to 35). Lower suppresses transient noise (claps, bumps). Below 10 risks affecting plosives.
    # maxDfThreshold = 12.000000;
    # maxErbThreshold: floating point number — Max ERB processing threshold in dB (-15 to 35). Lower reduces muffling on loud speech.
    # maxErbThreshold = 20.000000;
    # minProcessingBuffer: signed integer — Min processing buffer in frames (0-10). 0 = lowest latency.
    # minProcessingBuffer = 0;
    # minThreshold: floating point number — Min processing threshold in dB (-15 to 35).
    # minThreshold = -15.000000;
    # postFilterBeta: floating point number — Post-filter beta (0-0.05). 0 = disabled. DF3 is sufficient without it; higher values muffle voice.
    # postFilterBeta = 0.000000;
    # source: string — PipeWire node name of the raw microphone source
    # source = "alsa_input.usb-TC-Helicon_GoXLR-00.HiFi__Headset__source";
    # enable: boolean — Whether to enable GoXLR Mini support.
    # enable = false;
    # enable: boolean — Whether to enable EQ for Chat channel.
    # enable = true;
    # eq: string — PipeWire filter-chain EQ filter definition for Chat channel
    # eq = "filters = [
  { type = bq_highshelf, freq = 0, gain = -5.23, q = 1.0 },
  { type = bq_lowshelf, freq = 105.0, gain = 5.7, q = 0.70 },
