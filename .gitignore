# ── NixOS build outputs ──────────────────────────────────────────
result
result-*

# ── Working notes (contain live system output, not for tracking) ──
TODO.md

# ── Secrets & infrastructure identity ────────────────────────────
# All secret material — the agenix rules (secrets.nix) AND the encrypted *.age
# blobs — lives in the private, never-pushed `site` registry
# (repos/site/secrets/), NOT in this public repo. Nothing secret is tracked
# here; the rules below are defense-in-depth in case something ever strays in.
#   *.key, *.pem, *_rsa, *_ed25519, *_ecdsa — private keys
#   .env, .env.* — environment secrets
secrets/*
*.key
*.pem
*_rsa
*_ed25519
*_ecdsa
*.dec
*.unencrypted.yaml
.env
.env.*

# ── External package repos (independent git repos, see CLAUDE.md) ──
repos

# ── direnv + pre-commit state (machine-specific, generated) ──────
.direnv/
.pre-commit-config.yaml

# ── GSD worktree management ──────────────────────────────────────
.worktrees/
worktrees

# ── AI context (symlink to ~/.ai-context/project-state/nix/) ─────
# Not tracked — local symlink created per-machine, synced via Syncthing.
# No trailing slash: matches the symlink itself (not just directory contents).
.ai-context

# ── Root-level AI symlinks + tool dirs ───────────────────────────
# Relative symlinks resolved through .ai-context/. Never tracked.
/AGENTS.md
/CLAUDE.md
/GEMINI.md
/DEBT.md
/.claude/
/.gemini/
/.codex/
/.planning/
/.opencode/
/.crush/
/.pi/

# ── AI planning artifacts (session-generated, not documentation) ──
# Must live in .ai-context/, not docs/. Enforced by gitignore + hooks.
docs/brainstorms/
docs/plans/
docs/ROADMAP.md
docs/roadmap.md
docs/Roadmap.md

# ── AI tool artifacts ────────────────────────────────────────────
/.codex
/.nrb-update.lock
docs/SECURITY-AUDIT.md

# ── Syncthing conflict debris ────────────────────────────────────
*.sync-conflict-*

# ── Editor + OS cruft ────────────────────────────────────────────
*.swp
*.swo
*~
*.bak
*.tmp
.DS_Store
.vscode/
.idea/

# ── JS tooling (this is not a JS project; ignore defensively) ────
node_modules/
package.json
package-lock.json
pnpm-lock.yaml
yarn.lock
bunfig.toml
.npmrc
.yarnrc
.yarnrc.yml
openspec/

# AI context — symlink to .ai-context/AGENTS.md, never tracked
AGENTS.md

