# NixOS build outputs
result
result-*

# Secrets - NEVER commit private keys
/var/lib/sops-nix/key.txt
*.key
*.pem
*_rsa
*_ed25519
*_ecdsa

# Repositories
repos

# Unencrypted secrets (just in case)
secrets
secrets.yaml.dec
*.unencrypted.yaml
*.dec

# Temporary files
*.swp
*.swo
*~
*.bak
*.tmp
.DS_Store

# Editor directories
.vscode/
.idea/

# Exclude documentation and packages (separate repos)
documentation/
pkgs/
OCCT-nix/

# Exclude stray files
Todo.txt
*.txt

# direnv cache + pre-commit hook config (generated, machine-specific nix store paths)
.direnv/
.pre-commit-config.yaml

# AI context submodule
.ai-context/

# Root-level AI symlinks (Tracked via .ai-context submodule instead)
/CLAUDE.md
/GEMINI.md
/.claude/
/.gemini/

