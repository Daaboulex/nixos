# ── Working notes (contain live system output, not for tracking) ──
TODO.md

# ── Secrets & infrastructure identity ────────────────────────────
# Classification (enforced by check-secrets-leak hook + this gitignore):
#
#   TRACKED (public-safe):
#     secrets/secrets.nix — agenix public-key encryption rules only
#
#   GITIGNORED (infrastructure topology — Syncthing-synced):
#     secrets/host-identifiers.nix — Syncthing device IDs, internal IPs,
#       SSH pubkeys. Not cryptographic secrets but reveals topology.
#     secrets/*.age — encrypted secret blobs
#
#   GITIGNORED (cryptographic material):
#     *.key, *.pem, *_rsa, *_ed25519, *_ecdsa — private keys
#     .env, .env.* — environment secrets
#
# Rule: if unsure whether a file belongs in git, it does NOT.
# Only secrets/secrets.nix is negated. Everything else blocked.
secrets/*
!secrets/secrets.nix
*.key
*.pem
*_rsa
*_ed25519
*_ecdsa
*.dec
*.unencrypted.yaml
.env
.env.*

# ── External package repos (independent git repos, see CLAUDE.md) ──
repos

# ── direnv + pre-commit state (machine-specific, generated) ──────
.direnv/
.pre-commit-config.yaml

# ── GSD worktree management ──────────────────────────────────────
.worktrees/
worktrees

# ── AI context (symlink to ~/.ai-context/project-state/nix/) ─────
# Not tracked — local symlink created per-machine, synced via Syncthing.
# No trailing slash: matches the symlink itself (not just directory contents).
.ai-context

# ── Root-level AI symlinks + tool dirs ───────────────────────────
# Relative symlinks resolved through .ai-context/. Never tracked.
/AGENTS.md
/CLAUDE.md
/GEMINI.md
/DEBT.md
/.claude/
/.gemini/
/.codex/
/.planning/
/.opencode/
/.crush/

# ── Planning artifacts must live in .ai-context/.superpowers/ ────
# Enforced by check-no-roadmap-in-docs hook; gitignore here is belt-and-braces.
docs/ROADMAP.md
docs/roadmap.md
docs/Roadmap.md

