# shellcheck shell=bash

# ── Git sync check on direnv load ──────────────────────────────────────
# This tree IS synced by Syncthing (working tree only, .git/ excluded).
# Syncthing delivers files fast; git history syncs via push/pull.
# WARN when behind so the user pulls manually — never auto-pull (see
# .ai-context/memory/feedback_sync_warn_not_auto_fix.md).
if command -v git &>/dev/null && [ -d .git ]; then
  if git fetch origin main --quiet 2>/dev/null; then
    BEHIND=$(git rev-list HEAD..origin/main --count 2>/dev/null || echo 0)
    AHEAD=$(git rev-list origin/main..HEAD --count 2>/dev/null || echo 0)
    DIRTY=$(git status --porcelain 2>/dev/null | head -1)
    if [ "$BEHIND" -gt 0 ]; then
      echo ""
      if [ "$AHEAD" -eq 0 ] && [ -z "$DIRTY" ]; then
        echo "↓  $BEHIND commits behind origin/main — clean tree, ready to pull:"
        echo "   git pull --rebase origin main && git submodule update --init --recursive"
      else
        echo "⚠  $BEHIND commits behind origin/main (AHEAD=$AHEAD, DIRTY=$([ -z "$DIRTY" ] && echo no || echo yes))"
        echo "   Resolve manually: git status && git pull --rebase --autostash origin main"
      fi
      echo ""
    fi
  fi
fi

flake_args=()
host=$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo "")

remote_builder_reachable() {
  if command -v nc >/dev/null 2>&1 && nc -z -w 1 ryzen-9950x3d.local 22 >/dev/null 2>&1; then
    return 0
  fi

  command -v ping >/dev/null 2>&1 && ping -c 1 -W 1 ryzen-9950x3d.local >/dev/null 2>&1
}

if [ "$host" != "ryzen-9950x3d" ] && ! remote_builder_reachable; then
  flake_args=(--option builders "")
fi

use flake . "${flake_args[@]}"
